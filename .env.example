# ─── GHL (The Dojo) Configuration ────────────────────────────
# Get your API key from: GHL → Settings → Business Profile → API Keys
# Location ID is in the URL when viewing your sub-account
VITE_GHL_API_KEY=your-ghl-api-key-here
VITE_GHL_LOCATION_ID=3GI7SZRZHugGLBnDevX2

# ─── Supabase Configuration ──────────────────────────────────
# Create a free project at https://supabase.com
# Then run the migration SQL in supabase/migrations/001_initial_schema.sql
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Google Maps (for Route Optimizer) ────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key-here
